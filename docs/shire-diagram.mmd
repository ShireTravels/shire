classDiagram
direction LR

%% =========================
%% Screens
%% =========================
class AppNavigation {
  <<Composable>>
  +AppNavigation()
  +PlaceholderScreen(title: String)
}

class HomeScreen {
  <<Composable>>
  +HomeScreen(onNavigate)
  +SearchForm(onNavigate)
  +DestinationGrid(items)
}
class HomeScreenFlights {
  <<Composable>>
  +HomeScreenFlights(onNavigate)
  +FlightSearchForm()
}
class HomeScreenRent {
  <<Composable>>
  +HomeScreenRent(onNavigate)
  +RentSearchForm()
}
class TripsScreen {
  <<Composable>>
  +TripsScreen(onNavigate)
}
class TripDetailsScreen {
  <<Composable>>
  +TripDetailsScreen(tripId, onNavigateUp, onNavigate)
  +StatItem(value, label)
  +ItineraryItemRow(item)
}
class TripGalleryScreen {
  <<Composable>>
  +TripGalleryScreen(tripId, onNavigateUp)
  +GalleryPhotoCard(photo)
}
class CreateTripScreen {
  <<Composable>>
  +CreateTripScreen(onNavigateUp, onNavigate)
  +ShireDatePickerDialog(onDateSelected, onDismiss)
}
class HotelDetailsScreen {
  <<Composable>>
  +HotelDetailsScreen(onNavigateUp)
}
class ProfileScreen {
  <<Composable>>
  +ProfileScreen(onNavigate)
  +PreferenceCard()
  +PreferenceSectionTitle()
  +PreferenceChoiceItem()
  +PreferenceSwitchItem()
  +PreferenceNavItem()
  +PreferenceIcon()
}
class AboutScreen {
  <<Composable>>
  +AboutScreen(onNavigateUp)
  +TeamMember(initials, name, role, color)
}
class TermsScreen {
  <<Composable>>
  +TermsScreen(onNavigateUp)
  +TermsSection(title, content)
}

%% =========================
%% Components
%% =========================
class BottomNavBar {
  <<Composable>>
  +BottomNavBar(currentRoute, onNavigate)
}
class HeaderShire {
  <<Composable>>
  +HeaderShire(selectedCategory, onCategoryClick)
  +CategoryButton(label, isSelected, modifier, onClick)
}
class SectionTitle {
  <<Composable>>
  +SectionTitle(text, modifier)
}
class ShireButton {
  <<Composable>>
  +ShireButton(text, onClick, modifier, icon, containerColor, contentColor)
}
class ShireTextField {
  <<Composable>>
  +ShireTextField(value, onValueChange, label, modifier, placeholder, leadingIcon, enabled, onClick)
}
class ShireCard {
  <<Composable>>
  +ShireCard(title, subtitle, price, modifier, priceSuffix, annotation, icon)
}
class StepProgressBar {
  <<Composable>>
  +StepProgressBar(currentStep, steps, modifier)
}
class DestinationCard {
  <<Composable>>
  +DestinationCard(dest, modifier)
}
class TripCard {
  <<Composable>>
  +TripCard(trip, onClick)
}

%% =========================
%% UI Data Models
%% =========================
class PopularDestination {
  +city: String
  +country: String
  +imageRes: Int
}
class FlightInfo {
  +airline: String
  +departure: String
  +arrival: String
  +price: String
}
class CarRental {
  +model: String
  +type: String
  +pricePerDay: String
}
class UpcomingTrip {
  +id: String
  +title: String
  +dates: String
  +price: String
  +progress: Float
}
class ItineraryItem {
  +time: String
  +title: String
  +subtitle: String
  +cost: String
  +icon: ImageVector
  +iconTint: Color
  +iconBg: Color
}
class ItineraryDay {
  +dayTitle: String
  +items: List~ItineraryItem~
}
class GalleryPhoto {
  +id: Int
  +color: Color
  +isTop: Boolean
}
class MockHotel
class MockFlight
class MockCar
class MockSpot

